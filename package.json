{
  "name": "dfts-common",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "nx": "nx",
    "start": "nx serve",
    "build": "nx run-many --parallel 10 --target build --all",
    "test": "nx run-many --parallel 10 --target test --all --",
    "lint": "nx run-many --parallel 10 --target lint --all --fix",
    "lint:check": "nx run-many --parallel 10 --target lint --all",
    "graph": "nx graph",
    "format:check": "PRETTIER_EXPERIMENTAL_CLI=1 prettier --check .",
    "format": "PRETTIER_EXPERIMENTAL_CLI=1 prettier --write ."
  },
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "dependencies": {
    "chokidar": "5.0.0",
    "glob": "13.0.6",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@jscutlery/semver": "6.0.1",
    "@nx/devkit": "22.6.3",
    "@nx/eslint": "22.6.3",
    "@nx/eslint-plugin": "22.6.3",
    "@nx/jest": "22.6.3",
    "@nx/js": "22.6.3",
    "@nx/rollup": "22.6.3",
    "@nx/workspace": "22.6.3",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "@typescript-eslint/utils": "8.57.2",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsonc": "3.1.2",
    "fs-extra": "11.3.4",
    "jest": "30.3.0",
    "jest-canvas-mock": "2.5.2",
    "jest-environment-jsdom": "30.3.0",
    "jest-util": "30.3.0",
    "jsonc-eslint-parser": "3.1.0",
    "nx": "22.6.3",
    "prettier": "3.8.2",
    "prettier-plugin-organize-attributes": "1.0.0",
    "prettier-plugin-sort-json": "4.2.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "rollup": "4.60.1",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1"
  }
}
